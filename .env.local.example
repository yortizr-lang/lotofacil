# ============================================================
#  Base de datos MySQL  (Hostinger / local)
#  En Hostinger, con la app y la BD en el mismo hosting, DB_HOST = localhost.
#  Mientras estas variables estén COMENTADas, la app usa datos DEMO.
#  En producción defínelas en hPanel, NO en .env.local.
# ============================================================
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=tu_usuario_mysql
# DB_PASSWORD=tu_password_mysql
# DB_NAME=tu_base_de_datos

# Token para el endpoint de ingesta /api/ingesta (lo usa el scraper Node).
INGEST_TOKEN=cambia-esto-por-una-cadena-secreta-larga

# ============================================================
#  Ocultar el sitio durante el desarrollo (HTTP Basic Auth)
#  Si defines ambas, el sitio pide usuario/contraseña para verse.
#  Déjalas SIN definir (o bórralas en hPanel) el día del lanzamiento.
#  /api/ingesta queda fuera de esta protección (usa INGEST_TOKEN).
# ============================================================
SITE_USER=lotofacil
SITE_PASS=cambia-esta-clave
